extends AtmospherePreset

# =============================================================================
#  firewatch_sunset.gd
#  Пресет: золотой закат в духе Firewatch.
#  Характеристики: низкое солнце, тёплый amber fog, насыщенный контраст,
#  rim-glow на силуэтах деревьев, volumetric haze.
# =============================================================================

func _init() -> void:

	# -------------------------------------------------------------------------
	#  Небо (ProceduralSkyMaterial)
	# -------------------------------------------------------------------------
	sky_top_color              = Color(0.58, 0.24, 0.06)   # глубокий красно-коричневый зенит
	sky_horizon_color          = Color(0.98, 0.62, 0.10)   # ярко-янтарный горизонт
	sky_ground_horizon_color   = Color(0.80, 0.38, 0.08)   # ржавый под горизонтом
	sky_ground_bottom_color    = Color(0.20, 0.08, 0.02)   # почти чёрный низ

	sky_sun_angle_max          = 28.0   # узкий ореол — солнце у горизонта
	sky_sun_curve              = 0.12   # резкий, яркий диск

	# -------------------------------------------------------------------------
	#  Солнце (DirectionalLight3D)
	#  Угол в сцене: rotation_degrees = Vector3(-18, 45, 0)
	# -------------------------------------------------------------------------
	sun_color                  = Color(1.00, 0.60, 0.18)   # тёплый оранжево-жёлтый
	sun_energy                 = 1.85
	sun_angular_distance       = 0.6   # мягкий контур диска, чуть рассеянные тени

	# -------------------------------------------------------------------------
	#  Ambient
	# -------------------------------------------------------------------------
	ambient_color              = Color(0.72, 0.32, 0.08)   # тёплый amber ambient
	ambient_sky_contribution   = 0.55   # небо вносит основной вклад
	ambient_energy             = 0.40   # слабый, чтобы тени были глубокими

	# -------------------------------------------------------------------------
	#  Туман (стандартный)
	# -------------------------------------------------------------------------
	fog_enabled                = true
	fog_light_color            = Color(0.84, 0.48, 0.12)   # золотисто-оранжевый
	fog_sun_scatter            = 0.65   # scatter к солнцу усиливает glow
	fog_density                = 0.004  # лёгкая дымка; увеличь до 0.010 для плотного
	fog_aerial_perspective     = 0.45   # размытие дальних объектов

	# -------------------------------------------------------------------------
	#  Объёмный туман (volumetric)
	#  Требует Forward+ рендерер и включённый volumetric fog в ProjectSettings.
	# -------------------------------------------------------------------------
	volumetric_fog_enabled     = true
	volumetric_fog_density     = 0.022  # заметный, но не молочный

	# -------------------------------------------------------------------------
	#  Тональная кривая (Tonemapping)
	# -------------------------------------------------------------------------
	tonemap_mode               = Environment.TONE_MAPPER_FILMIC
	tonemap_exposure           = 1.25   # чуть ярче нейтрального
	tonemap_white              = 7.0    # высокий white — сохраняет яркие блики

	# -------------------------------------------------------------------------
	#  Glow / bloom
	# -------------------------------------------------------------------------
	glow_enabled               = true
	glow_intensity             = 0.55   # заметный, не кричащий
	glow_bloom                 = 0.12   # засветка светлых зон

	# -------------------------------------------------------------------------
	#  SSAO
	# -------------------------------------------------------------------------
	ssao_enabled               = true
	ssao_intensity             = 1.40   # усиленный — углы и кроны деревьев темнее

	# -------------------------------------------------------------------------
	#  Цветокоррекция
	# -------------------------------------------------------------------------
	adjustment_brightness      = 1.05
	adjustment_contrast        = 1.15   # контрастный, графичный
	adjustment_saturation      = 1.45   # насыщенность — визитная карточка стиля
